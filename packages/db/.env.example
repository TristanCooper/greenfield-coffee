# @greenfield/db — operator env (card 0.4)
#
# DATABASE_URL (pooler, port 6543) is what src/client.ts reads at runtime
# — used by the Next.js app via Vercel env vars.
#
# DATABASE_URL_DIRECT (port 5432) is what drizzle-kit reads at migrate-time
# — used by pnpm db:migrate / db:studio from the operator shell or CI.
#
# Copy to .env (gitignored) and fill from Supabase → Settings → Database.
# Append ?sslmode=require to both.
#
# See ../../SUPABASE.md for the "why two URLs" rationale.

DATABASE_URL=
DATABASE_URL_DIRECT=
